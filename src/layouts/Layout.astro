---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Mahamudal Hasan Masum — Career & Business Consultant | Dhaka',
  description = 'Consultant, career counselor, and founder of CareerKey.ai and MH Consultancy. Clarity, Direction, Growth — practical strategy for career and business decisions.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og-image.jpg', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Mahamudal Hasan Masum" />
    <meta name="theme-color" content="#0D2229" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Mahamudal Hasan Masum" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD: Person schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Mahamudal Hasan Masum',
      alternateName: 'Masum',
      jobTitle: 'Founder & CEO, Career & Business Consultant',
      description,
      url: canonicalURL,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Dhaka',
        addressCountry: 'BD',
      },
      worksFor: [
        { '@type': 'Organization', name: 'CareerKey.ai' },
        { '@type': 'Organization', name: 'MH Consultancy' },
      ],
      sameAs: [
        'https://mahamudal.substack.com',
        'https://calendly.com/careerkey-ai',
      ],
    })} />

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-ink focus:text-paper focus:px-4 focus:py-2 focus:rounded-md">
      Skip to content
    </a>
    <slot />

    <script>
      // Progressive-enhancement scroll reveal. Respects prefers-reduced-motion via CSS above.
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
