    <div>
      <p class="font-display text-lg text-paper">Mahamudal Hasan Masum</p>
      <p class="text-sm mt-1">Dhaka, Bangladesh</p>
    </div>

    <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm" aria-label="Footer">
      <a href="#about" class="hover:text-paper transition-colors">About</a>
      <a href="#services" class="hover:text-paper transition-colors">Services</a>
      <a href="#experience" class="hover:text-paper transition-colors">Experience</a>
      <a href="https://mahamudal.substack.com" target="_blank" rel="noopener noreferrer" class="hover:text-paper transition-colors">Newsletter</a>
      <a href="https://calendly.com/careerkey-ai" target="_blank" rel="noopener noreferrer" class="hover:text-paper transition-colors">Consultation</a>
