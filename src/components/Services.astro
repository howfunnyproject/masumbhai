    description: 'International university placement support, with particular depth in China, the UK, and beyond.',
  },
  {
    title: 'Resume Writing',
    description: 'CV and resume writing that presents a candidate\u2019s profile clearly to global employers and institutions.',
  },
  {
    title: 'Job Search Strategies',
