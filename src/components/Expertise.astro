---
const skills = [
  'Startup Development & Startups',
  'Career Counseling & Career Development',
  'Strategic Negotiations',
  'International Business & International Trade',
  'Strategic Sourcing',
  'Customer Support & Customer Service',
  'Recruitment Specialist & CV/Resume Writing',
  'Soft Skills Training (Communication, Leadership, Critical Thinking, Personal Branding)',
];
---

<section id="expertise" class="bg-paper py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10">
    <div class="reveal max-w-2xl mb-14">
      <p class="eyebrow mb-4">Expertise</p>
      <h2 class="font-display text-3xl md:text-[2.4rem] font-semibold text-ink leading-tight">
        Areas of expertise &amp; verified skills
      </h2>
    </div>

    <ul class="reveal stagger grid sm:grid-cols-2 gap-3 md:gap-4">
      {skills.map((s) => (
        <li class="lift flex items-start gap-3 bg-paper-light border border-black/5 rounded-card px-5 py-4">
          <span class="mt-2 w-1.5 h-1.5 rounded-full bg-gold shrink-0" aria-hidden="true"></span>
          <span class="text-sm md:text-[0.95rem] text-text-primary leading-relaxed">{s}</span>
        </li>
      ))}
    </ul>
  </div>
</section>
