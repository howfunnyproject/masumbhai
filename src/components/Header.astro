---
const links = [
  { href: '#about', label: 'About' },
  { href: '#services', label: 'Services' },
  { href: '#experience', label: 'Experience' },
  { href: '#expertise', label: 'Expertise' },
  { href: '#contact', label: 'Consultation' },
];
---

<header class="sticky top-0 z-50 bg-paper/90 backdrop-blur border-b border-black/5">
  <div class="max-w-content mx-auto px-6 md:px-10 h-[76px] flex items-center justify-between">
    <a href="#top" class="font-display text-lg font-semibold tracking-tight text-ink">
      Mahamudal Hasan <span class="text-gold">Masum</span>
    </a>

    <nav class="hidden md:flex items-center gap-9" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class="text-sm font-medium text-text-secondary hover:text-ink transition-colors duration-200"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <a
      href="https://calendly.com/careerkey-ai"
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:inline-flex items-center gap-2 rounded-full bg-ink text-paper text-sm font-medium px-5 py-2.5 hover:bg-ink-soft transition-colors duration-200"
    >
      Book a Consultation
    </a>

    <!-- Mobile menu -->
    <details class="md:hidden relative">
      <summary
        class="list-none cursor-pointer p-2 -mr-2 rounded-md"
        aria-label="Open menu"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-ink">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </summary>
      <div class="absolute right-0 top-12 w-56 bg-paper shadow-premium rounded-card border border-black/5 py-3">
        {links.map((l) => (
          <a href={l.href} class="block px-5 py-2.5 text-sm text-text-primary hover:bg-paper-light">
            {l.label}
          </a>
        ))}
        <a
          href="https://calendly.com/careerkey-ai"
          target="_blank"
          rel="noopener noreferrer"
          class="block mx-5 mt-2 rounded-full bg-ink text-paper text-sm font-medium px-5 py-2.5 text-center"
        >
          Book a Consultation
        </a>
      </div>
    </details>
  </div>
</header>
