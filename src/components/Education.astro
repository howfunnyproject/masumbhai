---
const education = [
  {
    school: 'BRAC University',
    degree: 'Masters Degree, Logistics, Materials, and Supply Chain Management',
    years: '2019–2027',
  },
  {
    school: 'National University',
    degree: 'Master of Science (MS), Physics',
    years: '2012–2013',
  },
  {
    school: 'National University',
    degree: 'Bachelor of Applied Science (BASc), Physics',
    years: '2008–2012',
  },
];
---

<section id="education" class="bg-ink-soft text-paper py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10">
    <div class="reveal max-w-2xl mb-14">
      <p class="eyebrow mb-4">Education</p>
      <h2 class="font-display text-3xl md:text-[2.4rem] font-semibold leading-tight">
        A foundation in physics, applied to logistics
      </h2>
    </div>

    <div class="reveal stagger grid md:grid-cols-3 gap-5 md:gap-6">
      {education.map((ed) => (
        <div class="rounded-card border border-paper/12 p-7">
          <p class="text-xs font-semibold tracking-[0.16em] uppercase text-gold">{ed.years}</p>
          <h3 class="mt-3 font-display text-lg font-semibold text-paper leading-snug">{ed.school}</h3>
          <p class="mt-2 text-sm text-paper/60 leading-relaxed">{ed.degree}</p>
        </div>
      ))}
    </div>
  </div>
</section>
