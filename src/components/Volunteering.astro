---
const causes = ['Education', 'Employment / Workforce Development'];
---

<section id="volunteering" class="bg-paper-light py-20 md:py-28">
  <div class="max-w-content mx-auto px-6 md:px-10 grid md:grid-cols-[0.5fr_0.5fr] gap-12 items-start">
    <div class="reveal">
      <p class="eyebrow mb-4">Volunteering</p>
      <h2 class="font-display text-3xl md:text-[2.2rem] font-semibold text-ink leading-tight">
        Causes I'm open to supporting
      </h2>
      <p class="mt-5 text-text-secondary leading-relaxed max-w-md">
        Beyond client work, I stay engaged with causes tied directly to the outcomes I help create every day.
      </p>
    </div>

    <div class="reveal flex flex-wrap gap-3">
      {causes.map((c) => (
        <span class="text-sm font-medium text-ink bg-paper border border-gold/30 rounded-full px-5 py-2.5">
          {c}
        </span>
      ))}
    </div>
  </div>
</section>
